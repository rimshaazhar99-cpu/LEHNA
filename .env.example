#
# Server env vars (Vercel → Project → Settings → Environment Variables)
#
# Waitlist endpoint (Google Apps Script Web App URL, ends with /exec)
#
WAITLIST_ENDPOINT=""

# Optional: local-only fallback (Vite dev server can't run Vercel functions).
# If you set this locally in `.env`, `npm run dev` can still submit directly.
VITE_WAITLIST_ENDPOINT=""

